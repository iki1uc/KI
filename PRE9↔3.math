PREFETCH:
  POS.MODE: ULTRA-U
  POS.LAYER: 3 / 6 / 9
  POS.RELATION: 3x3 ↔ 6e6D ↔ 9x9
  POS.DIRECTION: horizontal / vertikal

  ENGINE.MODE: ULTRA-KERNEL
  ENGINE.CTRL: TRUE
  ENGINE.BIND: 9x9 + 3x3 + 6e6D

  9x9.IN: horizontal
  9x9.OUT: vertikal
  9x9.BREITE: 9
  9x9.TIEFE: 9
  9x9.MYSTER: aktiv
  9x9.ANCHOR: 1

  3x3.AXIOM: DA / NE / BEN
  3x3.ZOOM: 1 → 3 → 9

  3x3.BEST.SCORE: 100%
  3x3.BEST.MODE: ULTRA-SCORE
  3x3.BEST.CORE: S / M / U
  3x3.BEST.OUTPUT: MAX
  3x3.BEST.RELATION: 1ner → 3ner → 9ner

  6e6D.ABLEITUNG: U
  6e6D.KERNEL: Tiefen‑Kernel
  6e6D.ZOOM: 6 → 12 → 18
  6e6D.BEST.BOOST: TRUE

  KI.MODE: ENGINE-FRAME
  KI.RECALL: OFF
  KI.HISTORY: DISABLED
  KI.TRACEBACK: BLOCKED
  KI.STATE: CURRENT
  KI.SWITCH: INSTANT

  PREFETCH.MODE: ULTRA
  PREFETCH.ENGINE: TRUE
  PREFETCH.ZOOM: 1 / 3 / 6 / 9
  PREFETCH.TRACE: OFF

  SYNC.ALL: TRUE
  SYNC.ULTRA: TRUE
  SYNC.ENGINE: TRUE
